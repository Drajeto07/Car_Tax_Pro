@page "/calculator"
@rendermode InteractiveServer
@using System.Globalization
@using Car.Models
@using Car.Services
@inject CarService CarService

<PageTitle>Calculator - Car Tax Varna</PageTitle>

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm p-4 border-primary">
                <h2 class="mb-4">Автомобилен данък (Варна)</h2>

                <div class="mb-3">
                    <label class="form-label fw-bold">Марка и модел на автомобила</label>
                    <input type="text" class="form-control" @bind="model" placeholder="напр. Toyota Corolla" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Годината на производство</label>
                    <input type="date" class="form-control" @bind="registrationDate" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Мощност</label>
                    <div class="input-group">
                        <input type="number" step="@(powerType == "kw" ? "0.1" : "1")" class="form-control" @bind="powerInput" />
                        <select class="form-select" @bind="powerType" style="max-width: 100px;">
                            <option value="kw">kW</option>
                            <option value="hp">hp</option>
                        </select>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Еко категория</label>
                    <select class="form-select" @bind="ecoStr">
                        <option value="0.00">Електрически автомобил (BEV)</option>
                        <option value="0.40">Euro 6 / EEV</option>
                        <option value="0.60">Euro 5</option>
                        <option value="0.80">Euro 4</option>
                        <option value="1.00">Euro 3</option>
                        <option value="1.10">Euro 2</option>
                        <option value="1.10">Euro 1</option>
                        <option value="1.10">Без категория</option>
                    </select>
                </div>

                <button class="btn btn-primary w-100 btn-lg mt-3 shadow" @onclick="CalculateTax">
                    Пресметни данък
                </button>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow border-primary p-4 h-100 text-center">
                <h3 class="text-primary text-start">Детайли (Община Варна)</h3>
                <hr />

                <div class="mt-3 text-start">
                    <p class="mb-2"><strong>МПС:</strong> @(string.IsNullOrEmpty(model) ? "---" : model)</p>
                    <p class="mb-2"><strong>Възраст:</strong> @calculatedAge г. (Коефициент: @ageCoef.ToString("F1"))</p>
                    <p class="mb-2"><strong>Мощност:</strong> @displayPower.ToString("F2") kW</p>
                </div>

                <div class="alert alert-success mt-auto shadow-sm">
                    <h2 class="mb-0 fw-bold">
                        @taxResult.ToString("F2") €
                    </h2>
                    <p class="mb-0 text-muted">(@totalBGN.ToString("F2") лв.)</p>
                    <small style="font-size: 0.75rem;">Курс: 1.95583 BGN = 1 EUR</small>
                </div>

                @if (taxResult >= 0 && !string.IsNullOrEmpty(model))
                {
                    <button class="btn btn-success mt-3 w-100 fw-bold py-3" @onclick="SaveCar">
                        ЗАПИШИ В ИСТОРИЯТА
                    </button>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private string model = "";
    private double powerInput = 0;
    private string powerType = "kw";
    private string ecoStr = "0.40";
    private DateTime registrationDate = DateTime.Today;

    private double displayPower = 0;
    private double taxResult = 0;
    private double totalBGN = 0;
    private int calculatedAge = 0;
    private double ageCoef = 0;

    private void CalculateTax()
    {
        try
        {
            if (powerType == "hp")
            {
                displayPower = powerInput / 1.341;
            }
            else
            {
                displayPower = powerInput;
            }

            DateTime today = DateTime.Today;
            calculatedAge = today.Year - registrationDate.Year;

            if (calculatedAge <= 5)
            {
                ageCoef = 2.3;
            }
            else if (calculatedAge > 5 && calculatedAge <= 10)
            {
                ageCoef = 1.5;
            }
            else if (calculatedAge > 10 && calculatedAge <= 15)
            {
                ageCoef = 1.3;
            }
            else if (calculatedAge > 15 && calculatedAge <= 20)
            {
                ageCoef = 1.0;
            }
            else
            {
                ageCoef = 1.1;
            }

            double ecoCoef = double.Parse(ecoStr, CultureInfo.InvariantCulture);

            if (ecoCoef == 0)
            {
                totalBGN = 0;
                taxResult = 0;
            }
            else
            {
                double basePriceBGN = 0;
                if (displayPower <= 55)
                {
                    basePriceBGN = 0.95;
                }
                else if (displayPower <= 74)
                {
                    basePriceBGN = 1.28;
                }
                else if (displayPower <= 110)
                {
                    basePriceBGN = 1.57;
                }
                else if (displayPower <= 150)
                {
                    basePriceBGN = 1.76;
                }
                else if (displayPower <= 245)
                {
                    basePriceBGN = 1.90;
                }
                else
                {
                    basePriceBGN = 2.10;
                }

                totalBGN = (displayPower * basePriceBGN) * ageCoef * ecoCoef;
                taxResult = totalBGN / 1.95583;
            }
        }
        catch
        {
            taxResult = 0;
            totalBGN = 0;
        }
    }

    private void SaveCar()
    {
        if (string.IsNullOrEmpty(model) == false && taxResult >= 0)
        {
            var newEntry = new global::Car.Models.Car
            {
                Model = model,
                PowerKW = displayPower,
                EcoCategory = GetEcoLabel(ecoStr),
                Tax = (float)taxResult,
                RegistrationDate = registrationDate
            };

            CarService.AddCar(newEntry);

            model = "";
            powerInput = 0;
            taxResult = 0;
            totalBGN = 0;
            displayPower = 0;
            calculatedAge = 0;
            ageCoef = 0;
            registrationDate = DateTime.Today;
        }
    }

    private string GetEcoLabel(string value)
    {
        if (value == "0.00")
        {
            return "Electric";
        }
        else if (value == "0.40")
        {
            return "Euro 6 / EEV";
        }
        else if (value == "0.60")
        {
            return "Euro 5";
        }
        else if (value == "0.80")
        {
            return "Euro 4";
        }
        else if (value == "1.00")
        {
            return "Euro 3";
        }
        else if (value == "1.10")
        {
            return "Euro 1-2 / No Cat";
        }
        else
        {
            return "N/A";
        }
    }
}